# ─────────────────────────────────────────────────────────────
# Financing in Canada — Environment Variables
# Copy this file to `.env` and fill in real values.
#
# The ONLY required external dependency is a PostgreSQL database.
# Image uploads are stored in Postgres (not S3/Cloudinary/Blob), so no
# object-storage service is needed. SMTP is optional (only for email).
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL) — local example below; on Vercel use Neon/Supabase.
# Neon pooled connection string works directly with Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financing_in_canada?schema=public"

# NextAuth — generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
# Set to your deployed URL on Vercel, e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (SEO, sitemap, canonical, OG tags) — your Vercel/production URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SMTP / Email (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="apikey-or-username"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="Financing in Canada <noreply@financingincanada.com>"
ADMIN_EMAIL="admin@financingincanada.com"

# Seed admin (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@financingincanada.com"
SEED_ADMIN_PASSWORD="Admin123!Change"
SEED_ADMIN_NAME="Super Admin"
